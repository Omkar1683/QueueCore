# ─── QueueCore Backend — Development Environment Variables ─────────────────────
# Copy this file to .env and adjust values for your local setup.
# NEVER commit a .env file with real secrets to version control.

# ─── Application ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── MongoDB ───────────────────────────────────────────────────────────────────
# Use mongo:27017 when running in Docker Compose, localhost:27017 for local dev
MONGO_URI=mongodb://mongo:27017/queuecore

# ─── JWT ───────────────────────────────────────────────────────────────────────
# IMPORTANT: Replace with cryptographically secure random strings in production
JWT_SECRET=queuecore_jwt_secret_dev_2024
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=queuecore_refresh_secret_dev_2024
JWT_REFRESH_EXPIRES_IN=30d

# ─── Redis ─────────────────────────────────────────────────────────────────────
# Set REDIS_ENABLED=false to run without Redis (queue works without it)
REDIS_ENABLED=true
REDIS_HOST=redis
REDIS_PORT=6379
# REDIS_PASSWORD=

# ─── Workers ───────────────────────────────────────────────────────────────────
WORKER_COUNT=3
WORKER_POLL_INTERVAL_MS=1000
WORKER_HEARTBEAT_INTERVAL_MS=10000
WORKER_VISIBILITY_TIMEOUT_MS=30000

# ─── Scheduler ─────────────────────────────────────────────────────────────────
SCHEDULER_INTERVAL_MS=5000

# ─── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── Circuit Breaker ───────────────────────────────────────────────────────────
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_COOLDOWN_MS=60000

# ─── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ─── Swagger API Docs ──────────────────────────────────────────────────────────
SWAGGER_ENABLED=true

# ─── CORS / Frontend ───────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
