# ===================================
# QueueCore Backend — Environment
# ===================================

# Application
NODE_ENV=development
PORT=5000

# MongoDB
MONGO_URI=mongodb://mongo:27017/queuecore

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_change_in_production
JWT_REFRESH_EXPIRES_IN=30d

# Redis (optional — set REDIS_ENABLED=false to disable)
REDIS_ENABLED=true
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Workers
WORKER_COUNT=3
WORKER_POLL_INTERVAL_MS=1000
WORKER_HEARTBEAT_INTERVAL_MS=10000
WORKER_VISIBILITY_TIMEOUT_MS=30000

# Scheduler
SCHEDULER_INTERVAL_MS=5000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Circuit Breaker
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_COOLDOWN_MS=60000

# Logging
LOG_LEVEL=info
LOG_DIR=logs

# Swagger
SWAGGER_ENABLED=true
